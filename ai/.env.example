# Copie para ai/.env e preencha os valores.

# LLM - Groq (gratuito): https://console.groq.com/keys
GROQ_API_KEY=

# Modelo do LLM
GROQ_MODEL=llama-3.3-70b-versatile

# Modelo de embedding local (baixado automaticamente via FastEmbed)
# Não precisa de API key — roda 100% local via onnxruntime
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Diretório onde o ChromaDB salva os dados
CHROMA_PATH=./chroma_db

# Diretório onde ficam os documentos de contexto (PDFs, TXTs)
DOCS_PATH=./docs
