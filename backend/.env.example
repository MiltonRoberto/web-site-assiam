# Variáveis de ambiente do BACKEND
# Configure no Render: Environment › Environment Variables
# Para desenvolvimento local, copie este arquivo para .env e preencha os valores.

PORT=3000

# ── InfinitePay ───────────────────────────────────────────────────
# Slug/handle da conta InfinitePay (obrigatório)
INFINITEPAY_HANDLE=seu_handle_aqui
# Em desenvolvimento local, usa uma URL de pagamento falsa que confirma o pedido sem InfinitePay.
MOCK_PAYMENT_ENABLED=true

# ── URLs públicas ─────────────────────────────────────────────────
# URL do frontend na Vercel (sem barra final) — usada no redirect pós-pagamento e CORS
APP_URL=https://seu-app.vercel.app
# URL do próprio backend no Render (sem barra final) — usada no webhook_url enviado à InfinitePay
API_URL=https://seu-app.onrender.com

# ── Google Sheets ─────────────────────────────────────────────────
# ID da planilha (parte da URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_SPREADSHEET_ID=
# Nome da aba onde os pedidos serão registrados
GOOGLE_SHEETS_SHEET_NAME=Pedidos AASIAM
# E-mail da Service Account (compartilhe a planilha com este e-mail como Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-conta@seu-projeto.iam.gserviceaccount.com
# Chave privada PEM — mantenha as quebras de linha como \n literais (não reais)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
# Alternativa: chave em Base64 (evita problemas com \n em alguns painéis)
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=

# n8n - e-mail de pedido
# Local: http://localhost:5678/webhook/order-email
# Producao: use a URL publica do seu n8n, por exemplo https://n8n.seu-dominio.com/webhook/order-email
N8N_ORDER_EMAIL_WEBHOOK_URL=http://localhost:5678/webhook/order-email
# Use o mesmo valor em n8n/.env para proteger o webhook.
N8N_WEBHOOK_SECRET=troque-este-segredo
# Fallback local quando MOCK_PAYMENT_ENABLED=true.
MAILPIT_SEND_URL=http://localhost:8025/api/v1/send
