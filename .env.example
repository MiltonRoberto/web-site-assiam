PORT=3333

# Mercado Pago
# Use as credenciais de teste primeiro.
# A public key vai no frontend; o access token fica só no servidor.
VITE_MP_PUBLIC_KEY=TEST-SEU_PUBLIC_KEY
MP_ACCESS_TOKEN=TEST-SEU_ACCESS_TOKEN

# Google Sheets
# Planilha de pedidos AASIAM
GOOGLE_SHEETS_SPREADSHEET_ID=1rpj9q_HWKynzpHM4EkQevdwzI7jQEjyzzqmao2TJuhw
GOOGLE_SHEETS_SHEET_NAME=Pedidos

# Service Account do Google Cloud (necessário para escrever na planilha)
# Compartilhe a planilha com o e-mail da service account antes de usar.
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-conta@seu-projeto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
