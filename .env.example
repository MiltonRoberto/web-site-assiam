PORT=3333

# InfinitePay — Checkout Integrado
# Seu handle (slug) da conta InfinitePay (obrigatório)
INFINITEPAY_HANDLE=seu_handle_aqui

# URLs públicas da aplicação
# Em dev local: use o endereço do ngrok se quiser testar webhooks reais
# Em produção:  https://seu-dominio.com
APP_URL=http://localhost:5173
API_URL=http://localhost:3333

# Google Sheets — planilha de pedidos AASIAM (opcional, mas recomendado)
# Compartilhe a planilha com o e-mail da service account antes de usar.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Pedidos
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-conta@seu-projeto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
# Alternativa sem problemas de quebra de linha (Base64 da chave PEM completa):
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=
