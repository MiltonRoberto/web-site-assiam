PORT=3333

# Mercado Pago
# Use as credenciais de teste primeiro. A public key fica no front-end; o access token fica so no servidor.
VITE_MP_PUBLIC_KEY=TEST-SEU_PUBLIC_KEY
MP_ACCESS_TOKEN=TEST-SEU_ACCESS_TOKEN
MP_WEBHOOK_SECRET=

# Google Sheets
# Compartilhe a planilha com o e-mail da service account antes de testar.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Pedidos
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"
# Alternativa para evitar problemas com quebras de linha:
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=
